{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "NEWSCP: 后端 (bootRun)",
      "type": "shell",
      "command": ".\\gradlew.bat bootRun --no-daemon",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "NEWSCP: 前端 (Vite)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "NEWSCP: 启动前后端",
      "dependsOn": ["NEWSCP: 后端 (bootRun)", "NEWSCP: 前端 (Vite)"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
